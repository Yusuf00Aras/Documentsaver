# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=yourhost            # Hostname or IP of the PostgreSQL server
DB_PORT=db_port             # Default PostgreSQL port
DB_USER=db_user             # Database user
DB_PASSWORD=yourpassword    # Database password
DB_NAME=documentsaver       # Name of the database to connect to

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=port                   # HTTP port the backend listens on (default: 80)
NODE_ENV=development        # "development" | "production" — affects cookie security

# ─── File Storage ─────────────────────────────────────────────────────────────
# Absolute or relative path where uploaded PDFs are stored.
# The basename is also used as the static-file URL prefix (e.g. /uploads/...).
STORAGE_PATH=./uploads

# ─── Google Gemini API ────────────────────────────────────────────────────────
# Required for document processing, embeddings, and chat features.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Both secrets are REQUIRED — the server will refuse to start without them.
# Use long, random strings (e.g. `openssl rand -hex 64`).
ACCESS_TOKEN_SECRET=your_access_token_secret_here    # Signs short-lived access tokens
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here  # Signs long-lived refresh tokens

# ─── Proxy (optional) ─────────────────────────────────────────────────────────
# Uncomment if your network requires a proxy for outbound requests.
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NODE_USE_ENV_PROXY=true
